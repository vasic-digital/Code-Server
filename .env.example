# .env.example — tracked template for a constitution-consuming project.
# Copy to `.env` (GIT-IGNORED per §11.4.30) and fill real values locally.
# PLACEHOLDERS ONLY here — never commit real secrets (§11.4.10). chmod 600 .env.
# `.env` is re-obtained from this template, never committed (§11.4.77).

# ── Release / tag naming (§11.4.151) ────────────────────────────────────────
# Authoritative prefix for every release tag + version name: "<PREFIX>-<version>"
# (e.g. codeserver-1.0.0-dev-0.0.1). MUST be identical across the main repo and
# every owned submodule in a release. If unset, scripts/release_prefix.sh falls
# back to the lowercased snake_case project-root directory name (§11.4.29).
HELIX_RELEASE_PREFIX=codeserver

# ── Operator / default workable-item assignee (§11.4.104 B, §11.4.148 D5) ────
# Per-messenger Operator handle. An unset item assignee defaults to this.
# Add one line per messenger channel you ship. Never logged (§11.4.10).
# HERALD_TGRAM_OPERATOR_USERNAME=@operator_handle_placeholder
# HERALD_SLACK_OPERATOR_USERNAME=@operator_handle_placeholder

# ── Action-prefix system (§11.4.140) — OPTIONAL ─────────────────────────────
# Override path to the actions registry YAML. Defaults to actions/registry.yaml.
# HELIX_ACTION_REGISTRY=/abs/path/to/constitution/actions/registry.yaml

# ── Translation pipeline — OPTIONAL (only if used) ──────────────────────────
# HELIX_TRANSLATE_BIN=/abs/path/to/unified-translator
# TRANSLATE_EVIDENCE_DIR=/abs/path/to/evidence/translate

# ── Credentials — NAMES ONLY, placeholders ONLY (§11.4.10) ──────────────────
# Loaded at runtime; never tracked, never echoed/logged. Uncomment + set locally
# the ones your wired services need. Rotate at the provider on suspected leak.
# EXTERNAL_TRACKER_API_TOKEN=EXAMPLE_VALUE_DO_NOT_USE
# HERALD_TGRAM_BOT_TOKEN=EXAMPLE_VALUE_DO_NOT_USE
# HERALD_SLACK_BOT_TOKEN=EXAMPLE_VALUE_DO_NOT_USE
