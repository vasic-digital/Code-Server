{
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.hg/**": true,
    "**/.svn/**": true,
    "**/CVS/**": true,
    "**/.repo/**": true,
    "**/node_modules/**": true,
    "**/bower_components/**": true,
    "**/.pnpm-store/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/output/**": true,
    "**/bin/**": true,
    "**/obj/**": true,
    "**/target/**": true,
    "**/.gradle/**": true,
    "**/.m2/**": true,
    "**/.cache/**": true,
    "**/.ccache/**": true,
    "**/vendor/**": true,
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/.tox/**": true,
    "**/.next/**": true,
    "**/.nuxt/**": true,
    "**/.terraform/**": true,
    "**/prebuilts/**": true,
    "**/*.git-backup*/**": true,
    "**/*-backup-*/**": true,
    "**/.git-backup*/**": true
  },
  "search.followSymlinks": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/target": true,
    "**/prebuilts": true,
    "**/*-backup-*": true
  }
}
