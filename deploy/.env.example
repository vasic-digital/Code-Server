# HelixCode deploy config. Copy to .env (git-ignored). NO real secrets here.
PORT_PREFIX=52
CODE_SERVER_PASSWORD=change-me-please
# colon-separated absolute host paths to expose as projects:
PROJECTS=

# ---------------------------------------------------------------------------
# TLS mode (edge HTTPS). See docs/guides/TLS.md for the full guide.
#   self-signed        (default) LAN box, no public domain — Caddy serves a
#                      per-boot self-signed cert for all SNI. Byte-for-byte the
#                      original HelixCode behavior. Accept the browser warning.
#   letsencrypt        REAL public Let's Encrypt. REQUIRES: a public domain in
#                      CS_DOMAIN that resolves to this host AND inbound :80/:443
#                      reachable from the internet (HTTP-01/TLS-ALPN-01), OR a
#                      DNS-01 provider (ACME_DNS_PROVIDER + a custom Caddy build
#                      with that DNS plugin). Auto-renews ~30 days pre-expiry.
#   letsencrypt-staging  Same, against LE staging (untrusted certs; for dry
#                      runs without burning production rate limits).
#   internal-acme      Point Caddy at ANY ACME directory URL (ACME_CA_URL) —
#                      e.g. a local Pebble / step-ca / smallstep CA. Used by the
#                      deploy/acme/ proof harness. Needs CS_DOMAIN + ACME_EMAIL.
TLS_MODE=self-signed

# FQDN Caddy issues/serves the cert for (letsencrypt* / internal-acme modes).
# Ignored by self-signed. Example: code.example.com
CS_DOMAIN=

# ACME account contact email (letsencrypt* / internal-acme). REQUIRED by those
# modes so the CA can reach you about expiry. Example: admin@example.com
ACME_EMAIL=

# Override the ACME directory URL. REQUIRED for internal-acme; optional for the
# others (letsencrypt-staging already sets the LE staging URL). Examples:
#   https://acme-v02.api.letsencrypt.org/directory          (LE production)
#   https://acme-staging-v02.api.letsencrypt.org/directory  (LE staging)
#   https://pebble:14000/dir                                (local Pebble CA)
ACME_CA_URL=

# Path (inside the caddy container) to a PEM root cert Caddy should TRUST for the
# ACME CA above (Caddy `acme_ca_root`). REQUIRED for internal-acme against a
# private CA (Pebble / step-ca) whose root is not in the system trust store.
# Optional for public letsencrypt* modes. Ignored by self-signed.
ACME_CA_ROOT=

# DNS-01 challenge (optional; for wildcard or when :80/:443 are not publicly
# reachable). Needs a Caddy image BUILT WITH the matching DNS provider plugin
# (the stock caddy:2 image has none). ACME_DNS_API_TOKEN is a SECRET: it lives
# only here in the git-ignored .env, is NEVER baked into the generated
# Caddyfile, and is passed to Caddy via the container env (see up.sh). Leave the
# token EMPTY in this example file (§11.4.10).
ACME_DNS_PROVIDER=
ACME_DNS_API_TOKEN=
