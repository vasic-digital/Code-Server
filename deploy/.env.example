# HelixCode deploy config. Copy to .env (git-ignored). NO real secrets here.
PORT_PREFIX=52

# ---------------------------------------------------------------------------
# Real-account editor auth (host-native code-server + helix-auth ssh-key gate).
# There is NO stored password: the login screen issues a challenge the user signs
# LOCALLY with their own SSH key (`ssh-keygen -Y sign`); the gate verifies the
# signature against the account's authorized_keys (`ssh-keygen -Y verify`) —
# nothing is written to repo / config / env / logs (§11.4.10).
# CODE_SERVER_PASSWORD is retired.
#
# HELIX_AUTH_MODE — only `sshkey` this release (ssh-key challenge-response).
HELIX_AUTH_MODE=sshkey
# HELIX_AUTH_ACCOUNT — the real host user account every editor session ties to
# (its ~/.ssh keys, ~/.bashrc exports, and all host binaries become available in
# the editor terminal). scripts/install-auth.sh substitutes it into the systemd
# --user unit templates.
HELIX_AUTH_ACCOUNT=milosvasic
# PROJECTS_ROOT — absolute host path opened as the code-server workspace (the
# Explorer DEFAULTS here). NOT a security boundary: the integrated terminal,
# File>Open-Folder, and extensions keep full real-user host access by design
# (see docs/guides/AUTH.md). Empty = open the user's home. Example:
#   PROJECTS_ROOT=/run/media/milosvasic/DATA4TB/Projects
PROJECTS_ROOT=
# HELIX_AUTH_AUTHORIZED_KEYS — SSH authorized_keys file whose public keys are the
# allowed signers for login. Empty = default ~/.ssh/authorized_keys of the account.
# NOTE (§11.4.6): the deployed gate currently reads the account's own
# ~/.ssh/authorized_keys (the systemd --user unit hardcodes %h/.ssh/authorized_keys);
# this .env value documents INTENT and is not yet wired into the running unit.
HELIX_AUTH_AUTHORIZED_KEYS=
# HELIX_AUTH_PRINCIPAL — ssh-key principal the login signature is verified for.
# Empty = default to HELIX_AUTH_ACCOUNT (the account name).
HELIX_AUTH_PRINCIPAL=
# HELIX_AUTH_TRUST_FORWARDED_FOR — the gate keys its per-client rate-limit on the
# RIGHTMOST X-Forwarded-For entry instead of its TCP peer (which is ALWAYS the
# Caddy edge here, so useless as a per-client key). It is set to `true` directly
# in deploy/systemd/helix-auth.service — NOT substituted from this file — because
# Caddy is the SOLE trusted reverse-proxy hop and sets XFF to the real client IP
# (a client-spoofed XFF is discarded by Caddy, never trusted). Documented here for
# awareness; change it in the unit, not via .env. Only ever `true` in this topology.

# ---------------------------------------------------------------------------
# TLS mode (edge HTTPS). See docs/guides/TLS.md for the full guide.
#   self-signed        (default) LAN box, no public domain — Caddy serves a
#                      per-boot self-signed cert for all SNI. Byte-for-byte the
#                      original HelixCode behavior. Accept the browser warning.
#   letsencrypt        REAL public Let's Encrypt. REQUIRES: a public domain in
#                      CS_DOMAIN that resolves to this host AND inbound :80/:443
#                      reachable from the internet (HTTP-01/TLS-ALPN-01), OR a
#                      DNS-01 provider (ACME_DNS_PROVIDER + a custom Caddy build
#                      with that DNS plugin). Auto-renews ~30 days pre-expiry.
#   letsencrypt-staging  Same, against LE staging (untrusted certs; for dry
#                      runs without burning production rate limits).
#   internal-acme      Point Caddy at ANY ACME directory URL (ACME_CA_URL) —
#                      e.g. a local Pebble / step-ca / smallstep CA. Used by the
#                      deploy/acme/ proof harness. Needs CS_DOMAIN + ACME_EMAIL.
TLS_MODE=self-signed

# FQDN Caddy issues/serves the cert for (letsencrypt* / internal-acme modes).
# Ignored by self-signed. Example: code.example.com
CS_DOMAIN=

# ACME account contact email (letsencrypt* / internal-acme). REQUIRED by those
# modes so the CA can reach you about expiry. Example: admin@example.com
ACME_EMAIL=

# Override the ACME directory URL. REQUIRED for internal-acme; optional for the
# others (letsencrypt-staging already sets the LE staging URL). Examples:
#   https://acme-v02.api.letsencrypt.org/directory          (LE production)
#   https://acme-staging-v02.api.letsencrypt.org/directory  (LE staging)
#   https://pebble:14000/dir                                (local Pebble CA)
ACME_CA_URL=

# Path (inside the caddy container) to a PEM root cert Caddy should TRUST for the
# ACME CA above (Caddy `acme_ca_root`). REQUIRED for internal-acme against a
# private CA (Pebble / step-ca) whose root is not in the system trust store.
# Optional for public letsencrypt* modes. Ignored by self-signed.
ACME_CA_ROOT=

# DNS-01 challenge (optional; for wildcard or when :80/:443 are not publicly
# reachable). Needs a Caddy image BUILT WITH the matching DNS provider plugin
# (the stock caddy:2 image has none). ACME_DNS_API_TOKEN is a SECRET: it lives
# only here in the git-ignored .env, is NEVER baked into the generated
# Caddyfile, and is passed to Caddy via the container env (see up.sh). Leave the
# token EMPTY in this example file (§11.4.10).
ACME_DNS_PROVIDER=
ACME_DNS_API_TOKEN=
